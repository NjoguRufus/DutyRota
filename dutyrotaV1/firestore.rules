rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    function isManager() {
      return isAuthenticated() && getUserRole() == 'manager';
    }

    function isAdminOrManager() {
      return isAdmin() || isManager();
    }

    function isStaff() {
      return isAuthenticated() && getUserRole() == 'staff';
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create: if isAdmin() || temporaryBootstrapAdminProfile();
      allow update, delete: if isAdmin();
    }

    function temporaryBootstrapAdminProfile() {
      return request.resource.data.role == 'admin'
        && request.resource.data.keys().hasAll(['email', 'name', 'role', 'createdAt'])
        && request.resource.data.email is string
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0;
    }

    match /staff/{staffId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && validStaffCreate(request.resource.data);
      allow update: if isAdmin() && validStaffUpdate();
      allow delete: if isAdmin();
    }

    function validStaffCreate(data) {
      return data.keys().hasAll(['fullName', 'department', 'email', 'phone', 'authUid', 'role', 'createdAt'])
        && data.fullName is string && data.fullName.size() > 0
        && data.department is string && data.department.size() > 0
        && data.email is string && data.email.matches('.*@.*\\..*')
        && data.phone is string
        && data.authUid is string && data.authUid.size() > 0
        && data.role == 'staff'
        && data.createdAt is timestamp;
    }

    function validStaffUpdate() {
      return request.resource.data.authUid == resource.data.authUid
        && request.resource.data.email == resource.data.email
        && request.resource.data.role == resource.data.role
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function staffCanReadRota() {
      return isStaff() && (
        resource.data.staffAuthUid == request.auth.uid
        || ((!('staffAuthUid' in resource.data) || resource.data.staffAuthUid == '')
          && resource.data.staffId == request.auth.uid)
      );
    }

    match /rotas/{rotaId} {
      allow read: if isAdminOrManager() || staffCanReadRota();
      allow create: if isAdminOrManager() && validRotaWrite(request.resource.data);
      allow update: if isAdminOrManager() && validRotaWrite(request.resource.data);
      allow delete: if isAdminOrManager();
    }

    function validRotaWrite(data) {
      return data.keys().hasAll([
          'staffId', 'staffAuthUid', 'staffName', 'shiftDate', 'shiftTime', 'department', 'status', 'createdAt', 'createdBy'
        ])
        && data.staffId is string
        // staffAuthUid can be empty (staff without linked portal login).
        && data.staffAuthUid is string
        && data.staffName is string
        && data.shiftDate is string
        && data.shiftTime is string
        && data.department is string
        && data.status is string
        && data.createdBy is string
        && data.createdBy.size() > 0
        && (data.createdAt == request.time || data.createdAt is timestamp);
    }

    function validNotificationCreate(data) {
      // createdAt: client uses serverTimestamp(); rules must use request.time (see Firebase docs).
      return data.keys().hasAll([
          'userType', 'targetUserId', 'title', 'message', 'type', 'read', 'createdAt'
        ])
        && (data.userType == 'staff' || data.userType == 'admin')
        && data.targetUserId is string
        && data.targetUserId.size() > 0
        && data.title is string
        && data.message is string
        && (data.type == 'rota_assigned' || data.type == 'system' || data.type == 'staff_created')
        && data.read is bool
        && (data.createdAt == request.time || data.createdAt is timestamp);
    }

    function notificationOwnerRead() {
      return resource.data.targetUserId == request.auth.uid;
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && notificationOwnerRead();
      allow create: if isAdminOrManager() && validNotificationCreate(request.resource.data);
      allow update: if isAuthenticated() && notificationOwnerRead();
      allow delete: if isAdminOrManager();
    }

    match /reports/{reportId} {
      allow read, write: if isAdmin();
    }

    match /departments/{departmentId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // New collection name (if you migrate later): managers/admins can write; staff read-only.
    // NOTE: Company scoping requires a stable company identifier shared by all users.
    match /rotaSchedules/{rotaId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdminOrManager();
    }
  }
}
