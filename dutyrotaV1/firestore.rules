rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // HELPER FUNCTIONS
    // ============================================
    
    // Check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Get the current user's role from their profile
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    // Check if the current user is an admin
    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }
    
    // Check if the current user is staff
    function isStaff() {
      return isAuthenticated() && getUserRole() == 'staff';
    }
    
    // ============================================
    // USERS COLLECTION
    // User profiles with roles (admin/staff)
    // ============================================
    match /users/{userId} {
      // Users can read their own profile
      allow read: if isAuthenticated() && request.auth.uid == userId;
      
      // Only admins can create/update/delete user profiles
      // (In practice, user creation is done via Firebase Console or Admin SDK)
      allow create, update, delete: if isAdmin();
    }
    
    // ============================================
    // EMPLOYEES COLLECTION
    // Staff members who can be assigned to rotas
    // ============================================
    match /employees/{employeeId} {
      // Any authenticated user can read employees
      allow read: if isAuthenticated();
      
      // Only admins can create, update, or delete employees
      allow create: if isAdmin() && validEmployeeData(request.resource.data);
      allow update: if isAdmin() && validEmployeeData(request.resource.data);
      allow delete: if isAdmin();
    }
    
    // Validate employee data structure
    function validEmployeeData(data) {
      return data.keys().hasAll(['name', 'department', 'email', 'phoneNumber'])
        && data.name is string
        && data.name.size() > 0
        && data.department is string
        && data.department.size() > 0
        && data.email is string
        && data.email.matches('.*@.*\\..*')
        && data.phoneNumber is string;
    }
    
    // ============================================
    // ROTAS COLLECTION
    // Duty shift schedules
    // ============================================
    match /rotas/{rotaId} {
      // Admins can read all rotas
      // Staff can only read rotas assigned to them
      allow read: if isAdmin() 
        || (isStaff() && resource.data.staffId == request.auth.uid);
      
      // Only admins can create, update, or delete rotas
      allow create: if isAdmin() && validRotaData(request.resource.data);
      allow update: if isAdmin() && validRotaData(request.resource.data);
      allow delete: if isAdmin();
    }
    
    // Validate rota data structure
    function validRotaData(data) {
      return data.keys().hasAll(['employeeId', 'employeeName', 'shiftDate', 'shiftTime', 'department'])
        && data.employeeId is string
        && data.employeeName is string
        && data.shiftDate is string
        && data.shiftTime is string
        && data.department is string;
    }
    
    // ============================================
    // REPORTS COLLECTION
    // Generated reports
    // ============================================
    match /reports/{reportId} {
      // Only admins can access reports
      allow read, write: if isAdmin();
    }
    
    // ============================================
    // DEPARTMENTS COLLECTION (optional)
    // List of departments
    // ============================================
    match /departments/{departmentId} {
      // Any authenticated user can read departments
      allow read: if isAuthenticated();
      
      // Only admins can modify departments
      allow write: if isAdmin();
    }
    
    // ============================================
    // SETTINGS COLLECTION (optional)
    // System settings
    // ============================================
    match /settings/{settingId} {
      // Any authenticated user can read settings
      allow read: if isAuthenticated();
      
      // Only admins can modify settings
      allow write: if isAdmin();
    }
  }
}
