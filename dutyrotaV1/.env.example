# Firebase Configuration
# Copy this file to .env and fill in your Firebase project values
# For Vite, all client-side env vars must be prefixed with VITE_

# Public site URL (no trailing slash). Used in index.html for og:image / WhatsApp link previews.
# Set this to your real production domain, e.g. https://capemedia.vercel.app
VITE_SITE_URL=https://capemedia.vercel.app

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id
